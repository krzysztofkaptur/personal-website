---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon'

import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

import type { TPost } from '../types/post'

interface Props {
	frontmatter: TPost
}

const { title, image, pubDate, description } = Astro.props.frontmatter;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
    <Nav />
    <a href={`${import.meta.env.BASE_URL}/blog`} class="flex gap-2"><Icon name="mdi:arrow-left" width={16} /> <span>Go back to posts</span></a>
    <h1>{title}</h1>
    <p>{description}</p>
    <span>{pubDate}</span>
    <Image src={image.url} alt={image.alt} width={600} height={400} />
		<slot />

    <section class="max-w-md m-auto">
      <h3>Similar articles</h3>
      <section class="flex justify-between gap-4">
        <article>
          <h4>Title</h4>
          <p>description</p>
        </article>
  
        <article>
          <h4>Title</h4>
          <p>description</p>
        </article>
  
        <article>
          <h4>Title</h4>
          <p>description</p>
        </article>
      </section>
    </section>
    <Footer />
	</body>
</html>